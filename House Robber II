// without using temp array
class Solution {
public:
    int rob(vector<int>& nums) {
        int n=nums.size();
        if(n==1)
            return nums[0];
        return max(fn(1,n,nums), fn(0,n-1,nums));
    }

     int fn(int start, int n,vector<int>& nums) {
            int prev=nums[start];
            int prev2=0;
            for(int i=start+1;i<n;i++){
                int take = nums[i];
                if(i>1) take+=prev2;
                
                int notTake = 0+ prev;

                int cur= max(take, notTake);

                prev2= prev;
                prev=cur;
            }
            return prev;
        }
};
